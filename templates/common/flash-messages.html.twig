{% set flash_icons = {
    'success': {
        'name': 'tabler:circle-check',
        'color': 'text-green-400'
    },
    'error': {
        'name': 'tabler:circle-x',
        'color': 'text-red-400'
    },
    'warning': {
        'name': 'tabler:alert-triangle',
        'color': 'text-yellow-400'
    },
    'info': {
        'name': 'tabler:info-circle',
        'color': 'text-blue-400'
    },
    'notice': {
        'name': 'tabler:info-circle',
        'color': 'text-blue-400'
    }
} %}

{% set flash_titles = {
    'success': 'Succès !',
    'error': 'Erreur',
    'warning': 'Attention',
    'info': 'Information',
    'notice': 'Information'
} %}

{# Global notification live region #}
<div aria-live="assertive"
     class="pointer-events-none fixed inset-0 z-50 flex items-end px-4 py-6 sm:items-start sm:p-6">
    <div class="flex w-full flex-col items-center space-y-4 sm:items-end">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                {% set icon = flash_icons[type] ?? flash_icons['info'] %}
                {% set title = flash_titles[type] ?? flash_titles['info'] %}

                {# Notification panel #}
                <div data-controller="flash-messages"
                     data-flash-messages-type-value="{{ type }}"
                     data-flash-messages-auto-close-value="true"
                     data-flash-messages-delay-value="5000"
                     data-action="mouseenter->flash-messages#pauseAutoClose mouseleave->flash-messages#resumeAutoClose"
                     class="pointer-events-auto w-full max-w-sm translate-y-0 transform rounded-lg bg-white opacity-100 shadow-lg outline-1 outline-black/5 transition duration-300 ease-out sm:translate-x-0 starting:translate-y-2 starting:opacity-0 starting:sm:translate-x-2 starting:sm:translate-y-0">
                    <div class="p-4">
                        <div class="flex items-start">
                            <div class="shrink-0">
                                <twig:ux:icon name="{{ icon.name }}" class="size-6 {{ icon.color }}"/>
                            </div>
                            <div class="ml-3 w-0 flex-1 pt-0.5">
                                <p class="text-sm font-medium text-gray-900">{{ title }}</p>
                                <p class="mt-1 text-sm text-gray-500">{{ message }}</p>
                            </div>
                            <div class="ml-4 flex shrink-0">
                                <button type="button"
                                        data-action="flash-messages#close"
                                        class="inline-flex rounded-md text-gray-400 hover:text-gray-500 focus:outline-2 focus:outline-offset-2 focus:outline-indigo-600">
                                    <span class="sr-only">Fermer</span>
                                    <twig:ux:icon name="tabler:x" class="size-5"/>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
</div>
