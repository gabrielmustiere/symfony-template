{
  "mcpServers": {
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": ["chrome-devtools-mcp@latest"]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "symfony-ai-mate": {
      "command": "./vendor/bin/mate",
      "args": ["serve", "--force-keep-alive"]
    }
  }
}
